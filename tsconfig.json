{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/renderer/*"],
      "@shared/*": ["src/shared/*"]
    },
    "types": ["vitest/globals"]
  },
  "include": [
    "src/renderer/**/*.ts",
    "src/renderer/**/*.vue",
    "src/shared/**/*.ts",
    "src/main/usageProvider.ts",
    "src/main/accountUsageHistory.ts",
    "src/main/deviceIdentity.ts",
    "cloud/netlify/functions/_shared/schema.ts",
    "tests/**/*.ts"
  ]
}
